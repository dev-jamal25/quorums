// boundary-interface.cs.template
//
// The canonical pattern for the six boundary interfaces (the swappable spine).
// Interface declared in Core; implementations in Infrastructure; registered in
// Program.cs with an explicit lifetime; selected (live vs mock) via configuration
// so CI runs entirely on mocks. Constructor injection only.
//
// Replace IExample / ExampleResult / Live + Mock impls with the real boundary, e.g.
//   IMediaGenerationTool : GeminiMediaTool / MockMediaTool
//   IMetaIntegration     : LiveMetaIntegration / MockMetaIntegration
//   IStorageService      : MinioStorage / LocalStorage
//   IRetrievalService    : PgVectorRetrieval
//   ISecretsProvider     : VaultProvider / EnvProvider
//   IEmbeddingProvider   : NomicEmbeddingProvider / mock

using System.Threading;
using System.Threading.Tasks;

namespace Core.Abstractions; // -> Core project

public interface IExample
{
    Task<ExampleResult> DoAsync(ExampleRequest request, CancellationToken ct = default);
}

public sealed record ExampleRequest(/* typed, validated inputs */);
public sealed record ExampleResult(/* typed outputs */);

// ---------------------------------------------------------------------------
// Infrastructure project: live implementation. Uses IHttpClientFactory for HTTP,
// timeouts + retries (Polly) on external calls, and returns a structured ToolError
// into the loop on recoverable failure instead of throwing (degrade, don't crash).
// ---------------------------------------------------------------------------
namespace Infrastructure.Integrations; // -> Infrastructure project

public sealed class ExampleLive : Core.Abstractions.IExample
{
    public Task<Core.Abstractions.ExampleResult> DoAsync(
        Core.Abstractions.ExampleRequest request,
        System.Threading.CancellationToken ct = default)
    {
        // call the real dependency; provider keys come from Options (Vault KV),
        // never inline.
        throw new System.NotImplementedException();
    }
}

public sealed class ExampleMock : Core.Abstractions.IExample
{
    public Task<Core.Abstractions.ExampleResult> DoAsync(
        Core.Abstractions.ExampleRequest request,
        System.Threading.CancellationToken ct = default)
        => Task.FromResult(new Core.Abstractions.ExampleResult(/* realistic canned values */));
}

