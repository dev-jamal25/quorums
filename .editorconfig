# EditorConfig — authoritative style rules enforced by `dotnet format`.
# Settles whitespace/naming arguments once; CI runs `dotnet format --verify-no-changes`.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space

[*.{cs,csx}]
indent_size = 4
# var usage
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
# prefer no `this.` qualifier
dotnet_style_qualification_for_field = false:warning
dotnet_style_qualification_for_property = false:warning
dotnet_style_qualification_for_method = false:warning
# expression preferences
csharp_prefer_braces = true:warning
dotnet_sort_system_directives_first = true

# Naming: private fields are _camelCase
dotnet_naming_rule.private_fields_underscore.severity = warning
dotnet_naming_rule.private_fields_underscore.symbols = private_fields
dotnet_naming_rule.private_fields_underscore.style = underscore_camel
dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_style.underscore_camel.required_prefix = _
dotnet_naming_style.underscore_camel.capitalization = camel_case

# Interfaces are I + PascalCase
dotnet_naming_rule.interfaces_prefixed.severity = warning
dotnet_naming_rule.interfaces_prefixed.symbols = interfaces
dotnet_naming_rule.interfaces_prefixed.style = i_pascal
dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_style.i_pascal.required_prefix = I
dotnet_naming_style.i_pascal.capitalization = pascal_case

[*.{json,jsonc,yml,yaml,csproj,props,targets}]
indent_size = 2

[*.{ts,tsx,js,jsx,mjs,cjs}]
indent_size = 2

[*.md]
trim_trailing_whitespace = false
