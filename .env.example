# Environment variable template — documents EVERY key BY NAME with NO real values.
# Copy to `.env` (git-ignored) and fill in for local `docker compose up`.
# In .NET, nested config keys use the double-underscore separator (Section__Key),
# and these override appsettings.json. No secret is ever committed.
#
# SCHEME CONVENTION: *__Endpoint and *__Address values store host:port ONLY —
# no http:// prefix. The application prepends http:// at registration time so the
# URI is never double-schemed regardless of what this file contains.

# --- Postgres (relational data, RLS, pgvector, Hangfire job store, checkpoints) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
ConnectionStrings__Postgres=

# --- Vault (KV app secrets + Transit per-brand token encryption) ---
# Vault__Enabled=false uses the dev fallback (config from appsettings.json + env).
# Set true to load KV secrets at startup; Vault__Token is then required (secret).
# Vault__Address is host:port only (no scheme) — the application prepends http://.
VAULT_DEV_ROOT_TOKEN_ID=
Vault__Enabled=
Vault__Address=
Vault__KvMount=
Vault__KvSecretPath=
Vault__TransitMount=
Vault__TransitKeyName=
Vault__Token=

# --- Anthropic (Claude — orchestration brain; key sourced from Vault KV in prod) ---
Anthropic__ApiKey=

# --- Gemini (media generation tool; key sourced from Vault KV in prod) ---
Gemini__ApiKey=
Gemini__BaseUrl=
Gemini__Model=gemini-2.5-flash-image

# --- MinIO (object storage for generated media, brand-prefixed) ---
# Minio__Endpoint is host:port only (no scheme) — the application prepends http://.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
Minio__Endpoint=
Minio__AccessKey=
Minio__SecretKey=
Minio__Bucket=

# --- Redis (IDistributedCache only — NOT the queue broker) ---
Redis__Configuration=

# --- Hangfire (PostgreSQL-backed job store; separate schema) ---
Hangfire__Schema=

# --- Embeddings (self-hosted nomic-embed-text-v1.5 over HTTP, DL-016) ---
# host-installed Ollama (default), api/worker running in compose:
Embeddings__BaseUrl=http://host.docker.internal:11434
# host-installed Ollama, api/worker running locally via `dotnet run`:
# Embeddings__BaseUrl=http://localhost:11434
# in-compose Ollama (opt-in via `docker compose --profile embeddings up`):
# Embeddings__BaseUrl=http://embeddings:11434
Embeddings__Model=
Embeddings__Dimension=

# --- Meta integration (mock by default; live is optional, human-gated) ---
Meta__Mode=

# --- Langfuse (optional run tracing) ---
# Leave ALL three empty to use the no-op local recorder — the run still populates
# its trace (visible at GET /runs/{id}/trace), it just isn't shipped to Langfuse.
# Set all three to ship spans. BaseUrl is a full URL (it is an API base, not a
# host:port endpoint); PublicKey/SecretKey are secrets.
Langfuse__BaseUrl=
Langfuse__PublicKey=
Langfuse__SecretKey=

# --- Frontend (browser-exposed API base URL) ---
NEXT_PUBLIC_API_BASE_URL=
