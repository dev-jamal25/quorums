# Environment variable template — documents EVERY key BY NAME with NO real values.
# Copy to `.env` (git-ignored) and fill in for local `docker compose up`.
# In .NET, nested config keys use the double-underscore separator (Section__Key),
# and these override appsettings.json. No secret is ever committed.
#
# SCHEME CONVENTION: *__Endpoint and *__Address values store host:port ONLY —
# no http:// prefix. The application prepends http:// at registration time so the
# URI is never double-schemed regardless of what this file contains.

# --- Postgres (relational data, RLS, pgvector, Hangfire job store, checkpoints) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
ConnectionStrings__Postgres=

# --- Vault (KV app secrets + Transit per-brand token encryption) ---
# Vault__Enabled=false uses the dev fallback (secrets from env/appsettings, passthrough crypto).
# Set true to load the app's KV secrets at startup AND use real Transit — Vault__Token is then required.
# Vault__Address is host:port only (no scheme) — the application prepends http://.
# Vault__Token is the dev root token (set it to the SAME value as VAULT_DEV_ROOT_TOKEN_ID).
# After `docker compose up` AND after every Vault restart (dev mode is in-memory), reseed Vault.
# The billing-attached API keys are injected TRANSIENTLY (never stored in this file or .env):
#   read -rs ANTHROPIC_KEY; echo; read -rs GEMINI_KEY; echo
#   docker compose run --rm --no-deps \
#     -e Anthropic__ApiKey="$ANTHROPIC_KEY" -e Gemini__ApiKey="$GEMINI_KEY" \
#     api Backend.Api.dll vault-seed
#   unset ANTHROPIC_KEY GEMINI_KEY
# Vault__Token + topology + the low-sensitivity dev creds (Postgres/Minio/Langfuse) come from this
# file. Then set Vault__Enabled=true and recreate api/worker so they read all secrets from Vault KV.
VAULT_DEV_ROOT_TOKEN_ID=
Vault__Enabled=
Vault__Address=vault:8200
Vault__KvMount=secret
Vault__KvSecretPath=quorums
Vault__TransitMount=transit
Vault__TransitKeyName=brand-tokens
Vault__Token=

# --- Anthropic (Claude — orchestration brain) ---
# Anthropic__ApiKey is INJECTED TRANSIENTLY at seed time — do NOT add it here or to .env. The seeder
# reads it from the process env and writes it to Vault KV; it never lands in a persistent file. See
# the secure seed command under "Vault" above. Re-inject on every seed (dev-mode Vault is wiped on
# restart; an un-injected re-seed silently skips it).
# Generation__ChatMode=live uses real Claude; unset/anything-else = deterministic offline client (no spend).
Generation__ChatMode=

# --- Gemini (media generation tool) ---
# Gemini__ApiKey is BILLING-ATTACHED — INJECTED TRANSIENTLY at seed time, NEVER in this file or .env
# (same transient-injection rule as Anthropic__ApiKey above).
Gemini__BaseUrl=
Gemini__Model=gemini-2.5-flash-image
# Gemini__Mode=live uses the real Gemini image API (billed); unset/anything-else = deterministic offline tool.
Gemini__Mode=

# --- MinIO (object storage for generated media, brand-prefixed) ---
# Minio__Endpoint is host:port only (no scheme) — the application prepends http://.
MINIO_ROOT_USER=
MINIO_ROOT_PASSWORD=
Minio__Endpoint=
Minio__AccessKey=
Minio__SecretKey=
Minio__Bucket=

# --- Redis (IDistributedCache only — NOT the queue broker) ---
Redis__Configuration=

# --- Hangfire (PostgreSQL-backed job store; separate schema) ---
Hangfire__Schema=

# --- Embeddings (self-hosted nomic-embed-text-v1.5 over HTTP, DL-016) ---
# host-installed Ollama (default), api/worker running in compose:
Embeddings__BaseUrl=http://host.docker.internal:11434
# host-installed Ollama, api/worker running locally via `dotnet run`:
# Embeddings__BaseUrl=http://localhost:11434
# in-compose Ollama (opt-in via `docker compose --profile embeddings up`):
# Embeddings__BaseUrl=http://embeddings:11434
Embeddings__Model=
Embeddings__Dimension=

# --- Meta integration (mock by default; live is optional, human-gated) ---
Meta__Mode=

# --- Langfuse (optional run tracing) ---
# Leave ALL three empty to use the no-op local recorder — the run still populates
# its trace (visible at GET /runs/{id}/trace), it just isn't shipped to Langfuse.
# Set all three to ship spans. BaseUrl is a full URL (it is an API base, not a
# host:port endpoint); PublicKey/SecretKey are secrets.
Langfuse__BaseUrl=
Langfuse__PublicKey=
Langfuse__SecretKey=

# --- Frontend (browser-exposed API base URL) ---
NEXT_PUBLIC_API_BASE_URL=

# --- CORS (browser origins allowed to call the API) ---
# The dashboard sends a custom X-Brand-Id header, so the browser preflights and the API must allow
# its origin. Indexed-array binding; add more as Cors__AllowedOrigins__1, __2, … Defaults to the dev
# frontend URL (appsettings.json) when unset.
Cors__AllowedOrigins__0=http://localhost:3000
