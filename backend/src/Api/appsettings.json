{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",

  "_note": "Non-secret dev defaults only. Secrets (ConnectionStrings:Postgres, Anthropic:ApiKey, Gemini:ApiKey, Minio:AccessKey, Minio:SecretKey, Vault:Token) are NOT stored here — supply them via env / Actions secrets / Vault KV. Missing required keys fail validation at startup.",

  "Vault": {
    "Enabled": false,
    "Address": "http://vault:8200",
    "KvMount": "secret",
    "KvSecretPath": "quorums",
    "TransitMount": "transit",
    "TransitKeyName": "brand-tokens"
  },
  "Gemini": {
    "BaseUrl": "https://generativelanguage.googleapis.com"
  },
  "Minio": {
    "Endpoint": "minio:9000",
    "Bucket": "media"
  },
  "Redis": {
    "Configuration": "redis:6379"
  },
  "Embeddings": {
    "Endpoint": "tei-embed:80",
    "Mode": "nomic",
    "Model": "nomic-embed-text-v1.5",
    "Dimension": 768
  },
  "Reranker": {
    "Endpoint": "tei-rerank:80",
    "Mode": "tei"
  },
  "QueryTransform": {
    "Model": "claude-haiku-4-5",
    "Mode": "chat"
  },
  "Retrieval": {
    "QueryTransformEnabled": false,
    "QueryVariants": 3,
    "DenseEnabled": true,
    "SparseEnabled": false,
    "RecallDepth": 20,
    "RerankEnabled": false,
    "FinalK": 5,
    "Blend": {
      "Alpha": 1.0,
      "Beta": 0.3,
      "Gamma": 0.0,
      "Delta": 0.3,
      "RecencyHalfLifeDays": 30.0
    }
  },
  "Hangfire": {
    "Schema": "hangfire"
  },
  "Meta": {
    "Mode": "mock"
  },
  "Langfuse": {
    "_note": "Optional tracing. Empty BaseUrl/keys = no-op local recorder (run never fails). Keys are secrets — supply Langfuse:PublicKey / Langfuse:SecretKey via env / Vault KV.",
    "BaseUrl": ""
  }
}
